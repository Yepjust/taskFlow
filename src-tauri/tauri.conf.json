{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../dist",
    "distDir": "../dist"
  },
  "package": {
    "productName": "TaskFlow",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "bundle": {
      "active": true,
     "icon": [
  "../dist/icons/icon-32.png",
  "../dist/icons/icon-128.png",
  "../dist/icons/icon-192.png",
  "../dist/icons/icon.ico"
    ],
      "identifier": "com.taskflow.app",
      "targets": ["msi", "nsis"]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "TaskFlow",
        "width": 1280,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  }
}
